# X Layer Testnet RPC
X_LAYER_RPC_URL=https://testrpc.xlayer.tech/terigon
X_LAYER_CHAIN_ID=1952

# Deployer wallet (create fresh for testnet, never use real funds)
PRIVATE_KEY=your_testnet_private_key_here

# OKX API (public endpoints work without key for reads; needed for DEX)
OKX_API_KEY=your_okx_api_key_here
OKX_SECRET_KEY=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here

# DeepSeek API (for the agent)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Deployed contract addresses (fill after deployment)
SESSION_KEY_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
FABRIC_X_ACCOUNT_ADDRESS=0x0000000000000000000000000000000000000000

# x402 payment recipient
X402_RECIPIENT=0x0000000000000000000000000000000000000000
